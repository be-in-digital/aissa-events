# Site
NEXT_PUBLIC_SITE_URL=https://aissaevents.com

# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=6ue0b6jo
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-05-09
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=contact@aissaevents.com
RESEND_TO_EMAIL=contact@aissaevents.com

# HubSpot
HUBSPOT_PRIVATE_APP_TOKEN=
HUBSPOT_PORTAL_ID=
HUBSPOT_PIPELINE_ID=

# Calendly
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/aissaevents/appel-decouverte

# Mux (via plugin Sanity)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Rate limiting + token store (Upstash Redis)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Sanity webhook revalidation (déjà utilisé par /api/revalidate)
SANITY_REVALIDATE_SECRET=

# ─────────────────────────────────────────────
# Phase 2 — Agent IA WhatsApp / Instagram
# Voir .context/whatsapp-deliverable.md pour la procédure complète
# ─────────────────────────────────────────────

# Meta App (Facebook Developer)
NEXT_PUBLIC_META_APP_ID=
META_APP_SECRET=
NEXT_PUBLIC_META_GRAPH_API_VERSION=v21.0

# Token de vérification du webhook Meta (handshake GET).
# À renseigner à l'identique dans Meta Developer → Webhooks → Verify token.
# Générer avec : openssl rand -base64 32
META_WEBHOOK_VERIFY_TOKEN=

# Clé de chiffrement AES-256-GCM pour les tokens Meta stockés dans Upstash.
# Générer avec : openssl rand -hex 32
META_ENCRYPTION_KEY=

# WhatsApp Cloud API — credentials du WABA connecté (System User Token).
# Voir .context/whatsapp-deliverable.md pour générer ces valeurs depuis Meta.
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Vercel AI Gateway — en local seulement (OIDC automatique en prod sur Vercel).
# Récupérer sur https://vercel.com/dashboard/ai-gateway
AI_GATEWAY_API_KEY=

# OpenAI direct (Whisper transcription — AI Gateway ne supporte pas l'audio).
OPENAI_API_KEY=

# Secret pour accéder à /admin/agent-health depuis le téléphone d'Aïssa.
# URL d'accès : https://aissaevents.com/admin/agent-health?secret=<valeur>
# Min 8 caractères. Générer avec : openssl rand -base64 24
ADMIN_AGENT_HEALTH_SECRET=

# Sentry DSN — optionnel. Si vide, les erreurs vont uniquement dans Vercel Logs.
# Récupérer sur https://sentry.io → Settings → Projects → DSN
SENTRY_DSN=

# Secret pour les routes /api/cron/* (Vercel Cron envoie automatiquement ce header).
# Générer : openssl rand -base64 32
CRON_SECRET=

# Instagram Business Account ID (récupérable via /me/accounts ou Meta Business Manager).
# Nécessaire uniquement si l'agent doit répondre aussi sur Instagram DM.
META_INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Numéro WhatsApp d'Aïssa pour recevoir les pings handover (format E.164 sans `+`).
# Ex : 33612345678
AISSA_NOTIFY_PHONE=
